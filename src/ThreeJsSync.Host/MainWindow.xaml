<Window x:Class="ThreeJsSync.Host.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:cef="clr-namespace:CefSharp.Wpf;assembly=CefSharp.Wpf"
        Title="Three.js ↔ .NET synchronization prototype" Width="1420" Height="900" MinWidth="1120" MinHeight="700"
        Background="#0B1020" Foreground="#DCE7FF">
  <Window.Resources>
    <Style TargetType="TextBox"><Setter Property="Background" Value="#0B1325"/><Setter Property="Foreground" Value="#E6EFFF"/><Setter Property="BorderBrush" Value="#35476C"/><Setter Property="Padding" Value="7"/><Setter Property="Margin" Value="2"/></Style>
    <Style TargetType="ComboBox"><Setter Property="Padding" Value="6"/></Style>
    <Style TargetType="Button"><Setter Property="Background" Value="#3269D8"/><Setter Property="Foreground" Value="White"/><Setter Property="BorderThickness" Value="0"/></Style>
    <Style x:Key="LabelStyle" TargetType="TextBlock"><Setter Property="Foreground" Value="#AAB9D4"/><Setter Property="FontSize" Value="12"/><Setter Property="Margin" Value="0,9,0,0"/></Style>
    <Style x:Key="SectionStyle" TargetType="TextBlock"><Setter Property="Foreground" Value="#7F99C8"/><Setter Property="FontSize" Value="11"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Margin" Value="0,15,0,4"/></Style>
  </Window.Resources>
  <Grid>
    <Grid.ColumnDefinitions><ColumnDefinition Width="350"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
    <Border Grid.Column="0" Background="#111A2E" BorderBrush="#293857" BorderThickness="0,0,1,0" Padding="22">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
          <TextBlock Text="HOST OBJECT" Foreground="#6F8FC8" FontSize="11" FontWeight="SemiBold"/>
          <TextBlock Text=".NET property editor" FontSize="24" FontWeight="SemiBold" Margin="0,4,0,20"/>
          <TextBlock Text="APPROACH" Style="{StaticResource LabelStyle}"/>
          <Border Background="#0B1325" BorderBrush="#35476C" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,5,0,14">
            <StackPanel>
              <TextBlock x:Name="ApproachNameText" FontWeight="SemiBold" Foreground="#E6EFFF"/>
              <TextBlock x:Name="ApproachDescriptionText" Margin="0,5,0,0" Foreground="#8EA4CB" FontSize="11" TextWrapping="Wrap"/>
            </StackPanel>
          </Border>
          <TextBlock Text="Name" Style="{StaticResource LabelStyle}"/><TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
          <TextBlock Text="Position" Style="{StaticResource SectionStyle}"/>
          <UniformGrid Columns="3"><TextBox Text="{Binding PositionX, UpdateSourceTrigger=PropertyChanged}"/><TextBox Text="{Binding PositionY, UpdateSourceTrigger=PropertyChanged}"/><TextBox Text="{Binding PositionZ, UpdateSourceTrigger=PropertyChanged}"/></UniformGrid>
          <TextBlock Text="Quaternion" Style="{StaticResource SectionStyle}"/>
          <UniformGrid Columns="4"><TextBox Text="{Binding QuaternionX, UpdateSourceTrigger=PropertyChanged}"/><TextBox Text="{Binding QuaternionY, UpdateSourceTrigger=PropertyChanged}"/><TextBox Text="{Binding QuaternionZ, UpdateSourceTrigger=PropertyChanged}"/><TextBox Text="{Binding QuaternionW, UpdateSourceTrigger=PropertyChanged}"/></UniformGrid>
          <TextBlock Text="Scale" Style="{StaticResource SectionStyle}"/>
          <UniformGrid Columns="3"><TextBox Text="{Binding ScaleX, UpdateSourceTrigger=PropertyChanged}"/><TextBox Text="{Binding ScaleY, UpdateSourceTrigger=PropertyChanged}"/><TextBox Text="{Binding ScaleZ, UpdateSourceTrigger=PropertyChanged}"/></UniformGrid>
          <CheckBox Content="Visible" IsChecked="{Binding Visible}" Margin="0,16,0,8"/>
          <TextBlock Text="Material color" Style="{StaticResource LabelStyle}"/><TextBox Text="{Binding MaterialColor, UpdateSourceTrigger=PropertyChanged}"/>
          <TextBlock Text="Material opacity" Style="{StaticResource LabelStyle}"/><Slider Minimum="0" Maximum="1" TickFrequency="0.01" Value="{Binding MaterialOpacity, UpdateSourceTrigger=PropertyChanged}"/>
          <TextBlock Text="Metadata note" Style="{StaticResource LabelStyle}"/><TextBox x:Name="MetadataNote" TextChanged="MetadataNote_OnTextChanged"/>
          <Button x:Name="BenchmarkButton" Content="Run 5 s warm-up + 30 s benchmark" Click="BenchmarkButton_OnClick" Margin="0,22,0,10" Padding="10"/>
          <TextBlock x:Name="ConnectionText" Text="Starting…" Foreground="#82E6BC" Margin="0,5" TextWrapping="Wrap"/>
          <Border Background="#0B1325" BorderBrush="#2A3B60" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,12,0,0">
            <TextBlock x:Name="MetricsText" FontFamily="Cascadia Mono,Consolas" FontSize="11" Foreground="#8FB4EE" TextWrapping="Wrap"/>
          </Border>
          <TextBlock x:Name="BenchmarkText" Margin="0,12,0,0" Foreground="#BFD1F2" TextWrapping="Wrap"/>
        </StackPanel>
      </ScrollViewer>
    </Border>
    <cef:ChromiumWebBrowser x:Name="Browser" Grid.Column="1" />
  </Grid>
</Window>
